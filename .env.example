# ===================================================
# LegalWakeely — Consolidated environment variables
# Copy to .env.local for development.
# ===================================================
# This single app merges:
#   - Wakeela (case accountability platform)
#   - Almustahar (Legal-AI document analysis — now a paid add-on)
# so it needs the union of both env sets.
# ===================================================

# ----- App -----
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# ----- Supabase (auth + db + storage) -----
# Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL="https://xxxxxxxxxxxx.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."   # server-only, never expose

# ----- CliQ (Jordan mobile payment — primary payment method) -----
# CliQ alias for receiving payments (e.g., legalwakeely@cliq)
CLIQ_ALIAS="legalwakeely@cliq"
CLIQ_ALIAS_NAME="LegalWakeely"

# ----- Resend (transactional email) -----
RESEND_API_KEY="re_..."
RESEND_FROM_EMAIL="LegalWakeely <noreply@legalwakeely.com>"

# ----- Gemini (Legal-AI module: analysis + RAG embeddings) -----
# https://aistudio.google.com/apikey
# Handles BOTH text analysis and 768-dim embeddings in one key.
GEMINI_API_KEY=""
GEMINI_TEXT_MODEL="gemini-2.5-flash"
GEMINI_EMBED_MODEL="gemini-embedding-001"

# ----- WhatsApp (NDE escalation, optional) -----
WHATSAPP_TOKEN=""
WHATSAPP_PHONE_NUMBER_ID=""
# Required only once WhatsApp features are turned on in production —
# without these set, the webhook safely rejects all incoming requests.
WHATSAPP_APP_SECRET=""
WHATSAPP_VERIFY_TOKEN=""

# ----- Cron job authentication -----
# Generate a random string yourself (e.g. `openssl rand -base64 32`)
# and set the same value here and in Vercel's env vars for Production.
# Vercel automatically sends it as a Bearer token to your cron routes.
CRON_SECRET=""

# ----- Analytics (optional) -----
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"

# ----- Error monitoring (optional, recommended for production) -----
# Easiest setup: Vercel dashboard → Integrations → add "Sentry" —
# it creates a project and sets these automatically. Without a DSN,
# error reporting safely no-ops rather than breaking the build.
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_ORG=""
SENTRY_PROJECT=""
SENTRY_AUTH_TOKEN=""

# ----- Upstash Redis (rate limiting + dedup) -----
# https://console.upstash.com → Redis → Create Database
UPSTASH_REDIS_REST_URL="https://xxx.upstash.io"
UPSTASH_REDIS_REST_TOKEN=""
