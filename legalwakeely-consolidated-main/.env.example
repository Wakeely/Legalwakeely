# ===================================================
# LegalWakeely — Consolidated environment variables
# Copy to .env.local for development.
# ===================================================
# This single app merges:
#   - Wakeela (case accountability platform)
#   - Almustahar (Legal-AI document analysis — now a paid add-on)
# so it needs the union of both env sets.
# ===================================================

# ----- App -----
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# ----- Supabase (auth + db + storage) -----
# Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL="https://xxxxxxxxxxxx.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."   # server-only, never expose

# ----- Stripe (base subscriptions + Legal-AI add-on) -----
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
# Base tiers
STRIPE_PRICE_BASIC_MONTHLY="price_..."
STRIPE_PRICE_BASIC_ANNUAL="price_..."
STRIPE_PRICE_PRO_MONTHLY="price_..."
STRIPE_PRICE_PRO_ANNUAL="price_..."
STRIPE_PRICE_PREMIUM_MONTHLY="price_..."
STRIPE_PRICE_PREMIUM_ANNUAL="price_..."
# Legal-AI add-on (orthogonal to base tier)
STRIPE_PRICE_LEGAL_AI_MONTHLY="price_..."

# ----- Resend (transactional email) -----
RESEND_API_KEY="re_..."
RESEND_FROM_EMAIL="LegalWakeely <noreply@legalwakeely.com>"

# ----- Gemini (Legal-AI module: analysis + RAG embeddings) -----
# https://aistudio.google.com/apikey
# Handles BOTH text analysis and 768-dim embeddings in one key.
GEMINI_API_KEY=""
GEMINI_TEXT_MODEL="gemini-2.5-flash"
GEMINI_EMBED_MODEL="gemini-embedding-001"

# ----- WhatsApp (NDE escalation, optional) -----
WHATSAPP_TOKEN=""
WHATSAPP_PHONE_NUMBER_ID=""

# ----- Analytics (optional) -----
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"
